# Runtime environment variables
# These are uploaded to Azure Key Vault as the 'env' secret

# App version (semver) — target prepared by /changelog, bumped after merge by version-log recording, and verified by deploy logging
APP_VERSION=0.1.0

# Basic Auth rollback user for the central proxy. OIDC mode uses Authentik
# instead, but this remains useful when EDGE_AUTH_MODE=basic.
BASIC_AUTH_USER=admin

# Storage Manager
SM_CHECK_INTERVAL_SECONDS=300
SM_LOG_LEVEL=INFO
SM_DB_PATH=/data/storage_manager.db
SM_API_PORT=9100
