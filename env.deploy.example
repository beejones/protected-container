# Deploy-time environment variables
# Used by scripts/deploy/azure_deploy_container.py and ubuntu_deploy.py
# NOT uploaded to Key Vault
#
# Staging keys: Set STAGING_* to enable staging deploys (ubuntu_deploy.py defaults to staging).
# Pass --prod to deploy to production instead.

# Azure authentication (set via 'az login' or GitHub Actions OIDC)
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# Required: Azure AD App Registration display name to use/ensure for GitHub Actions OIDC
AZURE_OIDC_APP_NAME=

# Resource configuration
AZURE_RESOURCE_GROUP=protected-azure-container-rg
AZURE_LOCATION=westeurope

# Azure Files
# Quota in GB for the Azure file shares created/managed by the deploy script.
# Note: Azure enforces minimums/maximums depending on share type; deploy will attempt to create/update.
AZURE_FILE_SHARE_QUOTA_GB=5

# Container image
APP_IMAGE=ghcr.io/your-user/protected-container:latest
CADDY_IMAGE=caddy:2-alpine
# OTHER_IMAGE=ghcr.io/your-user/other-service:latest

# Optional sizing overrides (defaults are used if unset)
APP_CPU_CORES=1.0
APP_MEMORY_GB=2.0
CADDY_CPU_CORES=0.5
CADDY_MEMORY_GB=0.5
# OTHER_CPU_CORES=0.25
# OTHER_MEMORY_GB=0.5

# Domain and TLS
PUBLIC_DOMAIN=your-domain.com
ACME_EMAIL=you@your-domain.com




# GHCR credentials (for private GHCR images)
# GHCR_USERNAME=

# Basic Auth (required for deployment to set runtime config? No, purely runtime)
# BASIC_AUTH_USER=admin

# Central edge auth (default remains Basic Auth until OIDC is configured and validated)
EDGE_AUTH_MODE=basic
EDGE_AUTH_GATEWAY=authentik
EDGE_AUTH_GATEWAY_SERVICE=authentik-server
EDGE_AUTH_GATEWAY_PORT=9000
EDGE_AUTH_VERIFY_URI=/outpost.goauthentik.io/auth/caddy
EDGE_AUTH_COPY_HEADERS='X-Authentik-Username>X-Auth-User,X-Authentik-Email>X-Auth-Email,X-Authentik-Groups>X-Auth-Groups,X-Authentik-Jwt>X-Auth-Token'
EDGE_AUTH_TOKEN_HEADER=X-Auth-Token
EDGE_AUTH_DEFAULT_PROOF_LEVEL=headers
# EDGE_AUTH_TOKEN_ISSUER=https://auth.your-domain.com/application/o/protected-container/
AUTH_POLICY=protected-container-users
AUTH_PROOF_LEVEL=headers
# AUTH_AUDIENCE=protected-container
# AUTH_SECRET_REF=authentik/protected-container/hmac-secret
AUTH_APPROVER_EMAIL=you@your-domain.com

# Authentik gateway settings (required when EDGE_AUTH_MODE=oidc)
# AUTHENTIK_PUBLIC_DOMAIN=auth.your-domain.com
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
AUTHENTIK_TAG=2026.5.2
AUTHENTIK_OUTPOST_SERVICE=authentik-server
AUTHENTIK_POSTGRESQL__HOST=authentik-postgresql
AUTHENTIK_POSTGRESQL__PORT=5432
AUTHENTIK_POSTGRESQL__NAME=authentik
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_STORAGE__BACKEND=file
AUTHENTIK_BACKUP_DIR=backups/authentik
# AUTHENTIK_BOOTSTRAP_EMAIL=admin@your-domain.com
# AUTHENTIK_EMAIL__HOST=smtp.example.com
AUTHENTIK_EMAIL__PORT=587
# AUTHENTIK_EMAIL__USERNAME=authentik@example.com
# AUTHENTIK_EMAIL__FROM='Authentik <authentik@example.com>'
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__USE_SSL=false
# AUTHENTIK_GOOGLE_CLIENT_ID=
# AUTHENTIK_MICROSOFT_CLIENT_ID=
# AUTHENTIK_FACEBOOK_CLIENT_ID=
# AUTHENTIK_SIGNING_KEY_REF=authentik-default-signing-key

# Optional default SSH target for ubuntu_deploy.py (used when --host is omitted)
UBUNTU_SSH_HOST=user@your-server

# Optional default remote path for ubuntu_deploy.py (used when --remote-dir is omitted)
UBUNTU_REMOTE_DIR=/home/your-user/containers/protected-container

# Optional defaults for no-arg ubuntu_deploy.py
# UBUNTU_COMPOSE_FILES=docker/docker-compose.yml,docker/docker-compose.ubuntu.yml
# UBUNTU_SYNC_SECRETS=true  # default is true when omitted
# WEB_PORT=8080  # optional; Ubuntu deploy derives the app port from Compose when omitted
# PORTAINER_HTTPS_PORT=443  # default when PUBLIC_DOMAIN derives portainer.your-domain.com; use 9943 for direct host access
# PORTAINER_WEBHOOK_INSECURE=false
# PORTAINER_WEBHOOK_URL=https://portainer.your-domain.com/api/stacks/webhooks/<token>
# PORTAINER_STACK_NAME=protected-container
# PORTAINER_ENDPOINT_ID=1
# STORAGE_MANAGER_API_URL=https://storage.your-domain.com
# STORAGE_MANAGER_IMAGE=ghcr.io/your-user/protected-container-storage-manager:latest
# STORAGE_MANAGER_DOCKERFILE=docker/storage-manager/Dockerfile

# Staging environment (optional — enables staging deploys via ubuntu_deploy.py)
# STAGING_PUBLIC_DOMAIN=staging-your-domain.com
# STAGING_REMOTE_DIR=/home/your-user/containers/protected-container-staging
# STAGING_PORTAINER_STACK_NAME=protected-container-staging
