# Deploy-time secrets
# NOT uploaded to Key Vault (used locally by deploy script)

# GitHub Container Registry (GHCR) Token
# Required for pulling the image if it's private.
GHCR_TOKEN=replace-with-ghcr-token

# Portainer stack webhook token (token tail only, not full URL)
PORTAINER_WEBHOOK_TOKEN=replace-with-portainer-webhook-token

# Optional full webhook URL. Prefer the token above when possible.
PORTAINER_WEBHOOK_URL=https://portainer.your-domain.com/api/stacks/webhooks/replace-with-portainer-webhook-token

# Optional: Portainer API auth for automatic webhook self-heal (token only)
PORTAINER_ACCESS_TOKEN=replace-with-portainer-api-token

# Authentik / central edge auth secrets (required when EDGE_AUTH_MODE=oidc).
# Generate strong values locally and never commit real values, for example:
# python3 - <<'PY'
# import secrets
# print('AUTHENTIK_SECRET_KEY=' + secrets.token_hex(32))
# print('AUTHENTIK_POSTGRESQL__PASSWORD=' + secrets.token_hex(24))
# print('AUTHENTIK_BOOTSTRAP_TOKEN=' + secrets.token_urlsafe(32))
# PY
AUTHENTIK_SECRET_KEY=replace-with-generated-hex-secret
AUTHENTIK_POSTGRESQL__PASSWORD=replace-with-generated-hex-password

# Optional first-start automation. Prefer the hash over a plaintext bootstrap password.
# Generate with: docker compose run --rm server hash_password 'your-password'
# Wrap hashes in single quotes to preserve dollar signs in dotenv parsing.
AUTHENTIK_BOOTSTRAP_PASSWORD_HASH=
AUTHENTIK_BOOTSTRAP_TOKEN=replace-with-generated-bootstrap-token

# Token used by scripts/deploy/auth_users.py for Authentik user/group provisioning.
AUTHENTIK_API_TOKEN=

# Optional SMTP and social-provider secrets.
AUTHENTIK_EMAIL__PASSWORD=
AUTHENTIK_GOOGLE_CLIENT_SECRET=
AUTHENTIK_MICROSOFT_CLIENT_SECRET=
AUTHENTIK_FACEBOOK_CLIENT_SECRET=
