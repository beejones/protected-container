# Deploy-time secrets
# NOT uploaded to Key Vault (used locally by deploy script)

# GitHub Container Registry (GHCR) Token
# Required for pulling the image if it's private.
GHCR_TOKEN=

# Portainer stack webhook token (token tail only, not full URL)
PORTAINER_WEBHOOK_TOKEN=

# Optional: Portainer API auth for automatic webhook self-heal (token only)
PORTAINER_ACCESS_TOKEN=

# Authentik / central edge auth secrets (required when EDGE_AUTH_MODE=oidc)
AUTHENTIK_SECRET_KEY=
AUTHENTIK_POSTGRESQL__PASSWORD=

# Optional first-start automation. Prefer the hash over a plaintext bootstrap password.
# Generate with: docker compose run --rm server hash_password 'your-password'
# Wrap hashes in single quotes to preserve dollar signs in dotenv parsing.
AUTHENTIK_BOOTSTRAP_PASSWORD_HASH=
AUTHENTIK_BOOTSTRAP_TOKEN=

# Token used by scripts/deploy/auth_users.py for Authentik API provisioning.
AUTHENTIK_API_TOKEN=

# Optional SMTP and social-provider secrets.
AUTHENTIK_EMAIL__PASSWORD=
AUTHENTIK_GOOGLE_CLIENT_SECRET=
AUTHENTIK_MICROSOFT_CLIENT_SECRET=
AUTHENTIK_FACEBOOK_CLIENT_SECRET=
