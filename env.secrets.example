# Runtime environment secrets
# These are uploaded to Azure Key Vault as the 'env-secrets' secret

# Basic Auth rollback hash for the central proxy when EDGE_AUTH_MODE=basic.
# Ubuntu/Portainer uses Docker Compose env_file parsing and proxy shell scripts source env files,
# so wrap bcrypt hashes in single quotes to preserve dollar signs:
# BASIC_AUTH_HASH='$2a$14$...'
BASIC_AUTH_HASH=

# Optional app secret (user-defined; only used if your runtime needs it)
APP_SECRET=

# Generate the raw hash with:
# docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
# Then wrap it in single quotes before putting it in this file for Ubuntu/Portainer deploys.
